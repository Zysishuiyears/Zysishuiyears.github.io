---
import type { EducationProfile } from '../data/education';
import type { Locale } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import ProfileSidebar from './ProfileSidebar.astro';

interface Props {
	locale: Locale;
	profile: EducationProfile;
}

const { locale, profile } = Astro.props;
const homeHref = locale === 'zh' ? '/' : '/en/';
const educationBase = locale === 'zh' ? '/education' : '/en/education';
const canonicalPath = `${educationBase}/${profile.slug}/`;
const alternatePath = locale === 'zh' ? `/en/education/${profile.slug}/` : `/education/${profile.slug}/`;
const labels = locale === 'zh'
	? { back: '返回教育经历', external: '在新窗口打开' }
	: { back: 'Back to education', external: 'Opens in a new tab' };
---

<BaseLayout
	locale={locale}
	title={`${profile.institution[locale]} | ${locale === 'zh' ? '姜政旭' : 'Zhengxu Jiang'}`}
	description={profile.summary[locale]}
	canonicalPath={canonicalPath}
	alternatePath={alternatePath}
>
	<Header locale={locale} switchHref={alternatePath} />
	<main class="site-shell" id="main-content">
		<ProfileSidebar locale={locale} />
		<article class="content-column project-detail education-detail" data-intro>
			<a class="back-link" href={`${homeHref}#experience`}><span aria-hidden="true">←</span> {labels.back}</a>
			<header class="project-hero education-hero">
				<p class="kicker">{profile.location[locale]} · {profile.period[locale]}</p>
				<h1>{profile.institution[locale]}</h1>
				<p class="education-degree-line">{profile.school[locale]} · {profile.degree[locale]}</p>
				{profile.showSummary !== false && <p class="project-lead">{profile.summary[locale]}</p>}
				{profile.advisor && (
					<div class="project-hero-actions">
						<a class="button-link" href={profile.advisor.url} target="_blank" rel="noreferrer">
							{profile.advisor.label[locale]}<span aria-hidden="true"> ↗</span><span class="sr-only">{labels.external}</span>
						</a>
					</div>
				)}
			</header>

			<div class="education-sections">
				{profile.sections.map((section) => (
					<section class="education-section" data-reveal>
						<h2>{section.title[locale]}</h2>
						<div class="education-section__content">
							{section.body && <p>{section.body[locale]}</p>}
							{section.items && (
								<ul>
									{section.items[locale].map((item) => <li>{item}</li>)}
								</ul>
							)}
							{section.experiences && (
								<div class="education-experience-list">
									{section.experiences.map((experience) => (
										<article class="education-experience">
											<div class="education-experience__head">
												<h3>{experience.role[locale]}</h3>
												<time>{experience.period[locale]}</time>
											</div>
											<ul>
												{experience.details[locale].map((detail) => <li>{detail}</li>)}
											</ul>
										</article>
									))}
								</div>
							)}
						</div>
					</section>
				))}
			</div>

			<footer class="project-footer education-footer">
				<a class="back-link" href={`${homeHref}#experience`}><span aria-hidden="true">←</span> {labels.back}</a>
			</footer>
		</article>
	</main>
</BaseLayout>
