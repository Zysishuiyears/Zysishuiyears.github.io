---
interface Props {
	id: string;
	title: string;
	icon: string;
	eyebrow?: string;
}

const { id, title, icon, eyebrow } = Astro.props;
---

<header class="section-heading" id={id} data-reveal>
	<div class="section-heading__title">
		<span class="section-heading__icon" aria-hidden="true">{icon}</span>
		<h2 id={`${id}-heading`}>{title}</h2>
	</div>
	{eyebrow && <p>{eyebrow}</p>}
</header>
