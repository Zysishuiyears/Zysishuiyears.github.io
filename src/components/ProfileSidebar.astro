---
import { Picture } from 'astro:assets';
import profilePhoto from '../assets/jiang-zhengxu.jpg';
import { githubUrl, homeContent, localeMeta, publicEmail, type Locale } from '../data/site';
import GraphMotif from './GraphMotif.astro';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const content = homeContent[locale];
const meta = localeMeta[locale];
---

<aside class="profile-sidebar" aria-label={locale === 'zh' ? '个人资料' : 'Profile'} data-profile>
	<div class="profile-photo-wrap">
		<Picture
			src={profilePhoto}
			formats={['avif', 'webp']}
			widths={[176, 352]}
			sizes="(min-width: 930px) 176px, 88px"
			alt={locale === 'zh' ? '姜政旭的个人照片' : 'Portrait of Zhengxu Jiang'}
			loading="eager"
			fetchpriority="high"
		/>
	</div>
	<div class="profile-copy">
		<div class="profile-name-row">
			<h1>{meta.name}</h1>
			<p class="profile-english-name">{meta.englishName}</p>
		</div>
		<p class="profile-bio">{content.profileBio}</p>
		<p class="profile-availability"><span aria-hidden="true"></span>{content.availability}</p>
		<ul class="profile-links">
			<li class="profile-link-item">
				<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s7-6.1 7-12a7 7 0 0 0-14 0c0 5.9 7 12 7 12Z" /><circle cx="12" cy="9" r="2.2" /></svg>
				<span>{content.profileLocation}</span>
			</li>
			<li class="profile-link-item">
				<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m3 9 9-5 9 5M5 10v8m4-8v8m6-8v8m4-8v8M3 20h18" /></svg>
				<span>{content.profileInstitution}</span>
			</li>
			<li>
				<a href={`mailto:${publicEmail}`}>
					<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 5.5h18v13H3zM4 7l8 6 8-6" /></svg>
					<span>Email</span>
				</a>
			</li>
			<li class="profile-github-link">
				<a href={githubUrl} target="_blank" rel="noreferrer">
					<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.8a9.3 9.3 0 0 0-2.9 18.1c.5.1.7-.2.7-.5v-1.8c-2.8.6-3.4-1.2-3.4-1.2-.5-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 0 1.6 1 1.6 1 .9 1.6 2.4 1.1 2.9.9.1-.7.4-1.1.7-1.3-2.2-.3-4.6-1.1-4.6-4.9 0-1.1.4-2 1-2.6-.1-.3-.4-1.3.1-2.6 0 0 .8-.3 2.7 1a9.4 9.4 0 0 1 4.9 0c1.9-1.3 2.7-1 2.7-1 .5 1.3.2 2.3.1 2.6.7.7 1 1.5 1 2.6 0 3.8-2.3 4.6-4.6 4.9.4.3.7 1 .7 1.9v2.8c0 .3.2.6.7.5A9.3 9.3 0 0 0 12 2.8Z" /></svg>
					<span>GitHub</span>
				</a>
			</li>
		</ul>
	</div>
	<GraphMotif />
</aside>
