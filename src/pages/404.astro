---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout locale="en" title="Page not found | Zhengxu Jiang" description="The requested page could not be found." canonicalPath="/404.html" alternatePath="/zh/">
	<main class="not-found" id="main-content">
		<p class="kicker">404</p>
		<h1>Page not found</h1>
		<p>The page you requested does not exist or has moved.</p>
		<p class="not-found-en">你访问的页面不存在，或地址已经发生变化。</p>
		<a class="button-link" href="/">Back home / 返回主页</a>
	</main>
</BaseLayout>
