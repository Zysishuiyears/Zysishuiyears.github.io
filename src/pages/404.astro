---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout locale="zh" title="页面未找到 | Zhengxu Jiang" description="The requested page could not be found." canonicalPath="/404.html" alternatePath="/en/">
	<main class="not-found" id="main-content">
		<p class="kicker">404</p>
		<h1>页面未找到</h1>
		<p>你访问的页面不存在，或地址已经发生变化。</p>
		<p class="not-found-en">The page you requested does not exist or has moved.</p>
		<a class="button-link" href="/">返回主页 / Back home</a>
	</main>
</BaseLayout>
